# Copy this file to .env and fill values locally.
# Never commit .env.

# Nimble API key from https://app.nimbleway.com / Nimble docs.
NIMBLE_API_KEY=your_nimble_api_key_here

# Optional: exact Nimble endpoint to call from the local proxy once selected.
# Keep blank for demo/status mode.
NIMBLE_API_URL=705618e165644ac1add4d73eaa2a8124ef8f6d6f75554570a832fa6aa5fd5f04 

# Optional ClickHouse settings for the same local proxy pattern.
CLICKHOUSE_HOST=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=openzerg
