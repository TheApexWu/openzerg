# Copy this file to .env and fill values locally.
# Never commit .env.

# Nimble API key from https://app.nimbleway.com
NIMBLE_API_KEY=your_nimble_api_key_here

# Optional: exact Nimble endpoint once selected.
NIMBLE_API_URL=

# Optional ClickHouse settings.
CLICKHOUSE_HOST=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=openzerg
